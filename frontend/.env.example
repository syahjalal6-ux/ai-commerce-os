# ─────────────────────────────────────────────────────────
# AI Commerce OS Indonesia — Environment Variables
# Copy this file to .env.local and fill in the values
# ─────────────────────────────────────────────────────────

# Google Apps Script Web App URL
# Deploy as Web App → Anyone can access → Get URL
APPS_SCRIPT_URL=https://script.google.com/macros/s/YOUR_SCRIPT_ID/exec

# Shared secret between Next.js and Apps Script
# Generate: openssl rand -hex 32
API_SECRET=your_random_secret_here_minimum_32_chars

# Frontend base URL (for SEO/OG tags)
NEXT_PUBLIC_APP_URL=https://aicommerceos.id

# Site metadata
NEXT_PUBLIC_APP_NAME=AI Commerce OS
NEXT_PUBLIC_APP_TAGLINE=Platform Toko Online Cerdas untuk UMKM Indonesia
